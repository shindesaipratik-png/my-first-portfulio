      <div class="caption">Panoramic view from the Waghora River gorge</div>
    </div>

    <div class="gallery-item">
      <img src="https://th.bing.com/th/id/OIP.SxL8FLpYIWwNlZTg1XkrFwHaFj?w=252&h=189&c=7&r=0&o=7&dpr=1.3&pid=1.7&rm=3" alt="Reclining Buddha" loading="lazy"/>
